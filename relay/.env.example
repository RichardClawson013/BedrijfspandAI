# Welke provider het doorgeefluik gebruikt: openrouter of google.
# Providerwissel is configuratie, geen code — zie SPEC.md §5.
PROVIDER=openrouter

# Model-id, specifiek voor de gekozen provider.
# openrouter bijvoorbeeld: anthropic/claude-sonnet-4.5
# google bijvoorbeeld: gemini-2.5-flash
MODEL=anthropic/claude-sonnet-4.5

# Sleutels voor de gekozen provider — komma-gescheiden: eerste sleutel is
# primair, de rest zijn backups. Bij een sleutel-gerelateerde fout
# (401/403/429) of netwerkfout probeert de relay automatisch de volgende
# sleutel in de lijst. Alleen de env-variabele van de actieve PROVIDER
# hoeft gevuld te zijn.
OPENROUTER_API_KEYS=primaire-sleutel-hier,backup-sleutel-hier
GOOGLE_API_KEYS=primaire-sleutel-hier,backup-sleutel-hier

ALLOWED_ORIGIN=https://richardclawson013.github.io
PORT=8787
